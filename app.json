{
  "expo": {
    "name": "LiveTrackingApp",
    "slug": "LiveTrackingApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "livetrackingapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.shivam004.LiveTrackingApp",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyByV5E8B_TD71Hb4d1HN6s-T6GiYCrTZtM"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.shivam004.LiveTrackingApp"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01fe44e1-6aad-4ce7-87f6-5a7e264ceb62"
      }
    }
  }
}
